# Shared
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Backend
PORT=4000
API_BASE_URL=http://localhost:4000/api
MONGODB_URI=mongodb://localhost:27017/flowmind
COSMOS_DB_CONNECTION_STRING=
COSMOS_DB_DATABASE=flowmind
JWT_AUDIENCE=api://your-api-client-id
MSAL_TENANT_ID=common
MSAL_CLIENT_ID=your-frontend-client-id
MSAL_CLIENT_SECRET=your-client-secret

# Microsoft Graph
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# No-Microsoft demo mode + Groq fallback
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Frontend
VITE_API_BASE_URL=http://localhost:4000/api
VITE_MSAL_CLIENT_ID=your-frontend-client-id
VITE_MSAL_TENANT_ID=common
VITE_MSAL_REDIRECT_URI=http://localhost:5173
VITE_GRAPH_SCOPES=User.Read Mail.Read Chat.Read ChatMessage.Read ChannelMessage.Read.All Team.ReadBasic.All
